<%- include('partials/header') %>

<div class="container">

    <!-- Page Title + Add Button -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Categories</h2>
        <a href="/categories/add" class="btn btn-success">+ Add Category</a>
    </div>

    <!-- Success Message -->
    <% if (successMessage) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= successMessage %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Categories Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-bordered mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Category ID</th>
                        <th>Category Name</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% if (categories.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                No categories found. <a href="/categories/add">Add one now!</a>
                            </td>
                        </tr>
                    <% } %>

                    <% categories.forEach(function(cat, index) { %>
                        <tr>
                            <td class="text-muted"><%= index + 1 %></td>
                            <td><%= cat.CategoryId %></td>
                            <td><strong><%= cat.CategoryName %></strong></td>
                            <td class="text-center">
                                <!-- Edit Button -->
                                <a 
                                    href="/categories/edit/<%= cat.CategoryId %>" 
                                    class="btn btn-warning btn-sm me-1"
                                >
                                    ✏️ Edit
                                </a>
                                <!-- Delete Button -->
                                <form 
                                    action="/categories/delete/<%= cat.CategoryId %>" 
                                    method="POST" 
                                    style="display:inline"
                                    onsubmit="return confirm('Delete <%= cat.CategoryName %>?')"
                                >
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        🗑️ Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>

            </table>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
